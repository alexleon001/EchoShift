# ============================================================================
# ECHOSHIFT - ENVIRONMENT VARIABLES
# ============================================================================
# Quick Start:
# 1. Copy this file: cp .env.example .env
# 2. Fill in your values
# 3. Never commit .env to git

# ----------------------------------------------------------------------------
# Claude API (Server only)
# ----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# ----------------------------------------------------------------------------
# Supabase
# ----------------------------------------------------------------------------
EXPO_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...

# ----------------------------------------------------------------------------
# Redis (Upstash) — Server only
# ----------------------------------------------------------------------------
UPSTASH_REDIS_URL=https://...
UPSTASH_REDIS_TOKEN=...

# ----------------------------------------------------------------------------
# RevenueCat (IAP)
# ----------------------------------------------------------------------------
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_...
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_...

# ----------------------------------------------------------------------------
# AdMob (Phase 2)
# ----------------------------------------------------------------------------
ADMOB_IOS_APP_ID=ca-app-pub-...
ADMOB_ANDROID_APP_ID=ca-app-pub-...
ADMOB_REWARDED_IOS=ca-app-pub-.../...
ADMOB_REWARDED_ANDROID=ca-app-pub-.../...

# ----------------------------------------------------------------------------
# App Config
# ----------------------------------------------------------------------------
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
EXPO_PUBLIC_ENVIRONMENT=development

# ----------------------------------------------------------------------------
# MCP Builder (AI tooling — inherited from starter template)
# ----------------------------------------------------------------------------
MCP_CATALOG_FILE='.gemini/settings.catalog.json'
MCP_FILE='.gemini/settings.json'
AI_COMMAND_PATH=''
